{
  "name": "catawiki-automation",
  "version": "1.0.0",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test --project=chromium",
    "test:api": "playwright test --project=api-web",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:ui": "playwright test --project=chromium --headed --grep @smoke",
    "test:smoke:api": "playwright test --project=api-web --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api:collections": "playwright test --project=api-web tests/api/collections-api.spec.ts",
    "test:api:lot-nav": "playwright test --project=api-web tests/api/lot-navigation-api.spec.ts",
    "test:api:lot-bids": "playwright test --project=api-web tests/api/lot-bids-api.spec.ts",
    "test:e2e:search": "playwright test --project=chromium tests/e2e/search.spec.ts",
    "test:e2e:lot": "playwright test --project=chromium tests/e2e/lot-page.spec.ts",
    "test:e2e:nav": "playwright test --project=chromium tests/e2e/navigation.spec.ts",
    "test:dev": "TEST_ENV=dev playwright test",
    "test:staging": "TEST_ENV=staging playwright test",
    "test:prod": "TEST_ENV=prod playwright test",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.7.0"
  }
}
